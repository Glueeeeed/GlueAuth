# Example configuration file for database connection settings
# Create a copy of this file named 'secrets.env' and fill in your actual database credentials.

DB_HOST="EnterYourDatabaseHostHere"
DB_NAME="EnterYourDatabaseNameHere"
DB_USER="EnterYourDatabaseUserHere"
DB_PASSWORD="EnterYourDatabasePasswordHere"
BASEKEY="EnterYourBaseKeyHere"
SESSION_SECRET_JWT="EnterYourJwtSecretHere"
